{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Bharatiya Watch Party",
  "version": "0.1.0",
  "identifier": "com.bharatiya.watchparty",
  "build": {
    "beforeDevCommand": "npm run dev --workspace @watchparty/desktop",
    "beforeBuildCommand": "npm run build --workspace @watchparty/desktop",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Bharatiya Watch Party",
        "width": 1440,
        "height": 960,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Entertainment",
    "shortDescription": "Watch the same stream together, in sync",
    "longDescription": "Bharatiya Watch Party is a cross-platform desktop app for watching the same stream together, in sync. A host loads a direct media URL and drives playback; viewers join with a room code and follow a single shared timeline.",
    "publisher": "Bharatiya Watch Party Contributors",
    "homepage": "https://github.com/anomalyco/opencode",
    "createUpdaterArtifacts": false,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {
        "language": "en-US",
        "version": "0.1.0"
      },
      "nsis": {
        "installMode": "currentUser",
        "displayLanguageSelector": false,
        "languages": ["English"]
      }
    },
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "10.15",
      "exceptionDomain": "127.0.0.1",
      "signingIdentity": null,
      "providerShortName": null,
      "entitlements": null,
      "dmg": {
        "windowSize": {
          "width": 660,
          "height": 400
        }
      }
    }
  }
}
