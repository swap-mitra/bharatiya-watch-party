# Sample environment file for a production deployment. Copy to `.env` and
# fill in real values; `.env` is git-ignored. Do NOT commit real credentials.

# Signal service bind address. Use 127.0.0.1 when behind a reverse proxy.
BIND_ADDR=0.0.0.0:4000

# Room TTL in seconds (default: 4 hours).
ROOM_TTL_SECONDS=14400

# Host reconnect grace in seconds (default: 60).
DISCONNECT_GRACE_SECONDS=60

# Comma-separated additional CORS origins for the signal service. Production
# deployments should list only the desktop identifier origin(s).
CORS_ALLOWED_ORIGINS=https://signal.example.com

# Reserved for future WebRTC signaling. Empty values disable the feature.
STUN_URLS=
TURN_URLS=
TURN_USERNAME=
TURN_CREDENTIAL=

# Build-time variables for the desktop app. These are baked into the bundle
# by `npm run build` / `tauri build`. Defaults are 127.0.0.1:4000.
# VITE_SIGNAL_SERVICE_URL=https://signal.example.com
# VITE_SIGNAL_SERVICE_WS_URL=wss://signal.example.com

# Runtime override for libmpv discovery (see docs/release/LIBMPV_BUNDLING.md).
# MPV_LIBRARY_PATH=/usr/local/lib/libmpv.so.2
